{
  "name": "@pwrdrvr/codex-app-server-protocol",
  "version": "0.144.0",
  "description": "TypeScript types for the Codex App Server JSON-RPC protocol, generated from `codex app-server generate-ts --experimental`. The package version mirrors the Codex CLI version used to generate it; the experimental protocol surface is included.",
  "author": "PwrDrvr LLC",
  "license": "MIT",
  "type": "module",
  "codexCliVersion": "0.144.0",
  "codexExperimental": true,
  "keywords": [
    "codex",
    "openai-codex",
    "app-server",
    "json-rpc",
    "protocol",
    "types",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pwrdrvr/codex-app-server-protocol.git"
  },
  "homepage": "https://github.com/pwrdrvr/codex-app-server-protocol#readme",
  "bugs": {
    "url": "https://github.com/pwrdrvr/codex-app-server-protocol/issues"
  },
  "exports": {
    ".": "./src/index.ts",
    "./v2": "./src/v2/index.ts"
  },
  "types": "./src/index.ts",
  "module": "./src/index.ts",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "generate": "${PWRDRVR_CODEX_BIN:-/Applications/Codex.app/Contents/Resources/codex} app-server generate-ts --out ./src --experimental",
    "regenerate": "bash scripts/regenerate.sh",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
